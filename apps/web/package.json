{
  "name": "@nexcv/web",
  "private": true,
  "version": "0.1.13",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "build:pdf-lambda": "node scripts/build-pdf-lambda.mjs",
    "build:pdf-worker-lambda": "pnpm --filter @nexcv/pdf-worker build:lambda",
    "build:cv-import-worker-lambda": "pnpm --filter @nexcv/cv-import-worker build:lambda",
    "build:email-worker-lambda": "pnpm --filter @nexcv/email-worker build:lambda",
    "build:ocr-lambda": "pnpm --filter @nexcv/ocr-lambda build:lambda",
    "validate:lambda-artifacts": "node scripts/validate-lambda-artifacts.mjs",
    "templates:release": "pnpm run validate:template-map && pnpm run validate:templates && node scripts/release-admin-templates.mjs",
    "templates:release:dry-run": "pnpm run validate:template-map && pnpm run validate:templates && node scripts/release-admin-templates.mjs --dry-run",
    "templates:verify-s3": "node scripts/verify-s3-template-assets.mjs",
    "templates:sync-thumbnails": "tsx scripts/sync-template-thumbnail-metadata.mjs",
    "templates:thumbnails": "tsx scripts/generate-template-thumbnails.mjs",
    "launch:check": "pnpm run lint && pnpm run test:run && pnpm run build && pnpm run validate:template-map && pnpm run validate:templates",
    "validate:template-map": "node scripts/validate-template-release-map.mjs",
    "validate:templates": "node scripts/validate-admin-templates.mjs",
    "render-build": "pnpm install --frozen-lockfile && pnpm run build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@nexcv/api-contracts": "workspace:*",
    "@nexcv/shared": "workspace:*",
    "@nexcv/templates": "workspace:*",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@sentry/react": "^10.54.0",
    "@tanstack/react-query": "^5.100.14",
    "dompurify": "^3.4.7",
    "lucide-react": "^0.546.0",
    "motion": "^12.40.0",
    "posthog-js": "^1.386.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-easy-crop": "^5.5.7",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^7.15.1",
    "react-simple-wysiwyg": "^3.4.1",
    "world-countries": "^5.1.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1055.0",
    "@sparticuz/chromium": "^147.0.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^22.19.17",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitest/coverage-v8": "^4.1.7",
    "@vitest/ui": "^4.1.7",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "dotenv": "^17.4.2",
    "esbuild": "^0.25.12",
    "jsdom": "^29.1.1",
    "mongoose": "^9.6.3",
    "puppeteer-core": "^24.43.1",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.3",
    "typescript": "~5.8.2",
    "vite": "^6.4.2",
    "vitest": "^4.1.7"
  }
}
