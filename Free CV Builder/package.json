{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "server": "tsx server.ts",
    "dev:all": "concurrently \"npm run server\" \"npm run dev\"",
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "render-build": "npm install && npm run build",
    "start": "tsx server.ts",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
