{
  "name": "@nexcv/main",
  "private": true,
  "version": "0.1.13",
  "type": "module",
  "scripts": {
    "server": "tsx server.ts",
    "dev:all": "concurrently \"pnpm run server\" \"pnpm run dev\"",
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "build:pdf-lambda": "node scripts/build-pdf-lambda.mjs",
    "build:pdf-worker-lambda": "pnpm --filter @nexcv/pdf-worker build:lambda",
    "build:cv-import-worker-lambda": "pnpm --filter @nexcv/cv-import-worker build:lambda",
    "build:email-worker-lambda": "pnpm --filter @nexcv/email-worker build:lambda",
    "build:ocr-lambda": "pnpm --filter @nexcv/ocr-lambda build:lambda",
    "templates:release": "pnpm run validate:template-map && pnpm run validate:templates && node scripts/release-admin-templates.mjs",
    "templates:release:dry-run": "pnpm run validate:template-map && pnpm run validate:templates && node scripts/release-admin-templates.mjs --dry-run",
    "templates:verify-s3": "node scripts/verify-s3-template-assets.mjs",
    "templates:sync-thumbnails": "tsx scripts/sync-template-thumbnail-metadata.mjs",
    "templates:thumbnails": "tsx scripts/generate-template-thumbnails.mjs",
    "launch:check": "pnpm run lint && pnpm run test:run && pnpm run build && pnpm run validate:template-map && pnpm run validate:templates",
    "validate:template-map": "node scripts/validate-template-release-map.mjs",
    "validate:templates": "node scripts/validate-admin-templates.mjs",
    "render-build": "pnpm install --frozen-lockfile && pnpm run build",
    "start": "tsx server.ts",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@aws-sdk/client-lambda": "^3.1058.0",
    "@aws-sdk/client-s3": "^3.1055.0",
    "@aws-sdk/client-sqs": "^3.1061.0",
    "@aws-sdk/client-textract": "^3.1058.0",
    "@nexcv/api-contracts": "workspace:*",
    "@nexcv/shared": "workspace:*",
    "@nexcv/templates": "workspace:*",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.8",
    "@sentry/node": "^10.54.0",
    "@sentry/react": "^10.54.0",
    "@sparticuz/chromium": "^147.0.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-query": "^5.100.14",
    "@tesseract.js-data/eng": "^1.0.0",
    "@vitejs/plugin-react": "^5.0.4",
    "bcryptjs": "^3.0.3",
    "connect-mongo": "^6.0.0",
    "cors": "^2.8.6",
    "dompurify": "^3.4.7",
    "dotenv": "^17.4.2",
    "express": "^4.22.2",
    "express-rate-limit": "^8.5.2",
    "express-session": "^1.19.0",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.546.0",
    "mongodb": "^7.2.0",
    "mongoose": "^9.6.3",
    "motion": "^12.40.0",
    "nodemailer": "^8.0.9",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pdf-parse": "^2.4.5",
    "puppeteer-core": "^24.43.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-easy-crop": "^5.5.7",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^7.15.1",
    "react-simple-wysiwyg": "^3.4.1",
    "tesseract.js": "^7.0.0",
    "world-countries": "^5.1.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/dompurify": "^3.0.5",
    "@types/express": "^4.17.25",
    "@types/express-session": "^1.19.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.19.17",
    "@types/nodemailer": "^8.0.0",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitest/coverage-v8": "^4.1.7",
    "@vitest/ui": "^4.1.7",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "esbuild": "^0.25.12",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.3",
    "typescript": "~5.8.2",
    "vite": "^6.4.2",
    "vitest": "^4.1.7"
  }
}
