{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "build:lambda": {
      "outputs": ["dist/*.zip"]
    },
    "build:pdf-lambda": {
      "outputs": ["lambda-pdf/dist/*.zip"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "test:run": {
      "dependsOn": ["^build"]
    },
    "launch:check": {},
    "validate:templates": {
      "cache": false
    },
    "validate:template-map": {
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "dev:all": {
      "cache": false,
      "persistent": true
    },
    "server": {
      "cache": false,
      "persistent": true
    },
    "preview": {
      "cache": false,
      "persistent": true
    }
  }
}
